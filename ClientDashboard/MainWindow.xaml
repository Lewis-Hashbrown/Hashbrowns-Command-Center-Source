<Window x:Class="ClientDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HashBrowns Command Center"
        Icon="/Icon.png"
        Width="1280" Height="720"
        MinWidth="800" MinHeight="500"
        WindowState="Maximized"
        Background="{StaticResource BgDark}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource BgMedium}" Padding="10,0">
            <Grid x:Name="TopBarRootGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="LeftTopBarPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="LaunchBtn"
                            Content="Launch DreamBot" Style="{StaticResource DashBtn}"
                            Click="LaunchBtn_Click"/>
                </StackPanel>

                <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <Viewbox x:Name="BrandTitleViewbox"
                             Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Height="48"
                             MaxWidth="760">
                        <Image x:Name="BrandTitleImage"
                               Source="/BrandTitle.png"
                               Stretch="Uniform"/>
                    </Viewbox>
                </Grid>

                <StackPanel x:Name="RightTopBarPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource BgLight}" CornerRadius="4" Padding="10,6" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock x:Name="UsageLabel" Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Text="CPU --  GPU --  MEM --"/>
                    </Border>
                    <Button x:Name="PrevPageBtn" Style="{StaticResource DashBtn}"
                            Content="&lt;"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="0"
                            FontSize="16"
                            Width="32" Margin="0,0,4,0" Click="PrevPageBtn_Click" Visibility="Collapsed"/>
                    <TextBlock x:Name="PageLabel" Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" FontSize="14" Visibility="Collapsed" Margin="0,0,4,0"/>
                    <Button x:Name="NextPageBtn" Style="{StaticResource DashBtn}"
                            Content="&gt;"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="0"
                            FontSize="16"
                            Width="32" Margin="0,0,8,0" Click="NextPageBtn_Click" Visibility="Collapsed"/>
                    <TextBlock x:Name="ClientCountLabel" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13"/>
                    <Button x:Name="MuteAllBtn" Content="Mute All: Off" Style="{StaticResource DashBtn}"
                            Margin="0,0,8,0" Click="MuteAllBtn_Click"/>
                    <Button x:Name="TileClickControlBtn" Content="Tile Click Control: On" Style="{StaticResource DashBtn}"
                            Margin="0,0,8,0" Click="TileClickControlBtn_Click"/>
                    <Button x:Name="CloseAllBtn" Content="Close All" Style="{StaticResource DashBtn}"
                            Margin="0,0,8,0" Click="CloseAllBtn_Click"/>
                    <Button x:Name="SettingsBtn" Content="&#9881;" Style="{StaticResource DashBtn}"
                            FontSize="18" Click="SettingsBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tile Grid -->
        <Border Grid.Row="1" Padding="4">
            <UniformGrid x:Name="TileGrid" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
        </Border>
    </Grid>
</Window>
